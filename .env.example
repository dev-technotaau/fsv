# Copy this file to `.env` (same directory) and fill in real values:
#   cp .env.example .env
#
# The scraper wrapper `scripts/scrape/run.sh` auto-loads `.env` before running.
# Any other entry point needs you to source it manually:
#   set -a; . .env; set +a
#   python -m data_scraper.cli run
#
# .env is already in .gitignore — never commit real keys.

# ============================================================
# PAID — Google APIs
# ============================================================

# Google Custom Search Engine (image search API).
#   Get key:  https://developers.google.com/custom-search/v1/introduction
#   Get CX:   https://programmablesearchengine.google.com/  (create engine with "Image search" ON)
#   Free tier: 100 queries/day. Above that: $5 per 1000.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Google Cloud Vision API (post-download fence verification, optional).
#   Setup: https://console.cloud.google.com/apis/library/vision.googleapis.com
#   Create a service account, download its JSON, point this var at the file path.
#   Cost: ~$1.50 per 1000 API calls. Use google_vision.sample_rate in scraper.yaml to reduce.
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================
# FREE WITH API KEY
# ============================================================

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pixabay — https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Flickr — https://www.flickr.com/services/api/misc.api_keys.html
FLICKR_API_KEY=

# ============================================================
# FREE — Gemini (used for query expansion)
# ============================================================

# Gemini 2.0 Flash API key — https://aistudio.google.com/app/apikey
# Generous free tier (15 RPM / 1M tokens/day); 1 scraper run uses 1 call.
GEMINI_API_KEY=

# ============================================================
# FREE — Reddit OAuth (6× rate limit vs unauthenticated)
# ============================================================

# Create a "script" app at https://www.reddit.com/prefs/apps
#   client_id     = 14-char string shown under the app name
#   client_secret = the "secret" field
# No Reddit user account actions needed — scraper uses client-credentials flow.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ============================================================
# OPTIONAL
# ============================================================

# Redis URL for distributed multi-machine mode (only if distributed.enabled=true in YAML).
# Example: redis://localhost:6379/0 or redis://:password@host:6379/0
REDIS_URL=

# HTTP proxies for rotation (only if proxy.enabled=true in YAML).
# Comma-separated list; supports http:// and socks5:// schemes.
# SCRAPER_PROXIES=http://user:pass@proxy1:8080,http://proxy2:8080

# Logger tuning (optional) — if set, override the YAML defaults at import time.
# For the log file path, use `runtime.log_file` in configs/scraper.yaml (no env var).
# SCRAPER_LOG_LEVEL=INFO            # DEBUG | INFO | WARN | ERROR
# SCRAPER_LOG_FORMAT=plain          # plain | json
